pipeline
{
agent any

tools
{
    jdk 'jdk-21'
    maven 'mymaven'
}



stages{

    stage('compile'){
        steps{
            sh 'mvn clean install -DskipTests -Dcheckstyle.skip=true'
        }
    }

    stage(sonar_analysis){
        steps{
            sh'''
             mvn sonar:sonar \
             -Dcheckstyle.skip=true\
            -Dsonar.host.url=http://18.206.222.184:9000 \
            -Dsonar.login=squ_e325604b23840e3fbdf607ee2525239c0b195b10\
            -Dsonar.projectKey=shopping_cart \
            -Dsonar.projectName=shopping_cart \
            -Dsonar.java.binaries=.
            '''

        }
    }

    stage('OWASP'){
        steps{

           withCredentials([string(credentialsId: 'nvd_api', variable: 'nvd_api_key')]) {

            dependencyCheck(
             additionalArguments: "--scan ./ --format XML --nvdApiKey ${nvd_api_key}",
             odcInstallation: 'dp-check'
    )
}
            
        }
    }

    stage('build'){
        steps{
            sh 'mvn clean install -DskipTests -Dcheckstyle.skip=true'
        }

    }

    stage('Docker build&push'){
        steps{
            script{
                  withDockerRegistry(credentialsId: 'docker-cred') {
               sh "docker build -t spc:latest -f Dockerfile ."
               sh "docker tag spc:latest vpk1999/spc:latest"
               sh "docker push vpk1999/spc:latest"
               
               }
            }
        }
    }
}
}